{
  "name": "@pautena/react-design-system",
  "version": "2.0.0-alpha.0",
  "description": "AI-ready design system built on shadcn/ui with MCP support",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./styles.css": "./dist/react-design-system.css",
    "./testing": {
      "types": "./dist/tests/index.d.ts",
      "import": "./dist/tests/index.mjs"
    }
  },
  "files": [
    "/dist"
  ],
  "scripts": {
    "build": "tsc && vite build && node -e \"const fs=require('fs');const files=['actions','assertions'];files.forEach(f=>{const src='dist/'+f+'.d.ts';const dest='dist/tests/'+f+'.d.ts';if(fs.existsSync(src)){fs.renameSync(src,dest);}});const index=files.map(f=>'export * from \\'./'+f+'\\';').join('\\\\n');fs.writeFileSync('dist/tests/index.d.ts',index);\"",
    "publish:npm": "npm publish --access public",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverarge",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build && tsx scripts/generate-llms.ts",
    "storybook:prod": "storybook dev --ci --no-open --host 0.0.0.0 --port 6006",
    "generate-llms": "tsx scripts/generate-llms.ts",
    "build:registry": "npx shadcn@latest build registry.json --output public/r",
    "lint": "biome check --write --unsafe --no-errors-on-unmatched --files-ignore-unknown=true ./",
    "check": "biome check ./",
    "check:ts": "tsc -p ."
  },
  "keywords": [
    "shadcn",
    "design-system",
    "react",
    "tailwind",
    "components",
    "ui",
    "mcp",
    "ai-ready"
  ],
  "author": "Pau Tena Vidal",
  "license": "MIT",
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "@emotion/utils": "^1.0.0",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@mui/system": "^7.3.8",
    "@mui/x-date-pickers": "^8.27.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "date-fns-jalali": "^4.1.0-0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.574.0",
    "next-themes": "^0.4.6",
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-day-picker": "^9.13.2",
    "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-resizable-panels": "^4.6.4",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.1",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@biomejs/biome": "2.4.3",
    "@faker-js/faker": "^10.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@storybook/addon-docs": "^10.2.8",
    "@storybook/addon-links": "^10.2.8",
    "@storybook/addon-mcp": "^0.3.1",
    "@storybook/addon-onboarding": "^10.2.8",
    "@storybook/addon-themes": "^10.2.8",
    "@storybook/react": "^10.2.8",
    "@storybook/react-vite": "^10.2.8",
    "@tailwindcss/postcss": "^4.1.13",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "babel-loader": "^10.0.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "globals": "^17.3.0",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.6",
    "react-docgen-typescript": "^2.4.0",
    "react-test-renderer": "^19.2.4",
    "storybook": "^10.2.8",
    "tailwindcss": "^4.1.13",
    "tailwindcss-animate": "^1.0.7",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "@emotion/utils": "^1.0.0",
    "@types/react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pautena/react-design-system.git"
  },
  "bugs": {
    "url": "https://github.com/pautena/react-design-system/issues"
  },
  "homepage": "https://react-design-system.pautena.com/"
}
