{
  "name": "@pautena/react-design-system",
  "version": "2.0.0-alpha.0",
  "description": "AI-ready design system built on shadcn/ui with MCP support",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./testing": {
      "types": "./dist/tests/index.d.ts",
      "import": "./dist/tests/index.mjs"
    }
  },
  "files": [
    "/dist"
  ],
  "scripts": {
    "build": "tsc && vite build && node -e \"const fs=require('fs');const files=['actions','assertions'];files.forEach(f=>{const src='dist/'+f+'.d.ts';const dest='dist/tests/'+f+'.d.ts';if(fs.existsSync(src)){fs.renameSync(src,dest);}});const index=files.map(f=>'export * from \\'./'+f+'\\';').join('\\\\n');fs.writeFileSync('dist/tests/index.d.ts',index);\"",
    "publish:npm": "npm publish --access public",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverarge",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build && tsx scripts/generate-llms.ts",
    "storybook:prod": "storybook dev --ci --no-open --host 0.0.0.0 --port 6006",
    "generate-llms": "tsx scripts/generate-llms.ts",
    "build:registry": "npx shadcn@latest build registry.json --output public/r",
    "lint": "biome check --write --unsafe --no-errors-on-unmatched --files-ignore-unknown=true ./",
    "check": "biome check ./",
    "check:ts": "tsc -p ."
  },
  "keywords": [
    "shadcn",
    "design-system",
    "react",
    "tailwind",
    "components",
    "ui",
    "mcp",
    "ai-ready"
  ],
  "author": "Pau Tena Vidal",
  "license": "MIT",
  "dependencies": {
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "@emotion/utils": "^1.0.0",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^6.0.0",
    "@mui/system": "^7.3.8",
    "@mui/x-date-pickers": "^7.0.0",
    "@radix-ui/react-accordion": "^1.2.12",
